{
  "name": "apnaservo-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Production backend for ApnaServo user and partner apps.",
  "main": "src/server.js",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "check": "powershell -NoProfile -Command \"Get-ChildItem src -Recurse -Filter *.js | ForEach-Object { node --check $_.FullName }\"",
    "check:unix": "find src -name '*.js' -print0 | xargs -0 -n1 node --check",
    "audit:e2e": "node scripts/e2e-workflow-audit.js",
    "db:audit": "node scripts/db-audit.js",
    "db:audit:schema": "node scripts/db-audit.js --schema-only",
    "db:migrate": "node scripts/db-migrate-fixes.js",
    "db:reset-users-partners": "node scripts/reset-users-partners.js",
    "scale:simulate": "node scripts/scale-simulation.js",
    "security:audit": "node scripts/security-audit.js",
    "seed:admin": "node scripts/seed-admin.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "mongoose": "^8.20.1",
    "morgan": "^1.10.1",
    "multer": "^2.2.0",
    "pdfkit": "^0.18.0",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.11"
  }
}
