PORT=5000
NODE_ENV=production
REQUIRE_CUSTOMER_PHONE_OTP=false
CLIENT_ORIGIN=https://your-admin-domain.example
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/apnaservo?retryWrites=true&w=majority

FIREBASE_PROJECT_ID=apna-servo
# Local laptop development can use a file path.
FIREBASE_SERVICE_ACCOUNT_PATH=C:/Users/Admin/Downloads/apna-servo-firebase-adminsdk.json
# Cloud hosting should use FIREBASE_SERVICE_ACCOUNT_JSON instead of a local file path.
# Generate one-line JSON with:
# node scripts/firebase-json-one-line.js C:/Users/Admin/Downloads/apna-servo-firebase-adminsdk.json
FIREBASE_SERVICE_ACCOUNT_JSON=

# 32-byte key used for app-level AES-256-GCM encryption of sensitive MongoDB fields.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Admin-only backend routes. Comma-separated Firebase UIDs or emails.
ADMIN_FIREBASE_UIDS=
ADMIN_EMAILS=
# Shared secret used by the ApnaServo admin dashboard for backend admin REST/socket access.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_API_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

DEFAULT_PARTNER_RADIUS_KM=25

# Bounded fanout for push/SMS/in-app notifications.
# Start with 8 on small Render instances; raise to 16/24 only after checking DB and FCM latency.
NOTIFICATION_CONCURRENCY=8
# Scheduled admin campaigns are checked every 30 seconds by default.
NOTIFICATION_SCHEDULER_INTERVAL_MS=30000
# Set true only when another worker owns scheduled delivery.
DISABLE_NOTIFICATION_SCHEDULER=false
